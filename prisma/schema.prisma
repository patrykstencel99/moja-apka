generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActivityType {
  BOOLEAN
  NUMERIC_0_10
}

enum BadgeType {
  FIRST_CHECKIN
  STREAK_7
  CHECKINS_30
  THREE_ENTRIES_ONE_DAY
  CHECKINS_7
  CHECKINS_100
  CHECKINS_300
  CHECKINS_1000
  STREAK_3
  STREAK_14
  STREAK_21
  STREAK_30
  STREAK_60
  STREAK_100
  STREAK_365
  THREE_CHECKINS_7_DAYS
  THREE_CHECKINS_30_DAYS
  TIER_T2_UNLOCK
  TIER_T3_UNLOCK
  TIER_T3_KEEP_7
  TIER_T3_KEEP_30
  COMEBACK_3_DAYS
  COMEBACK_7_DAYS
  PERFECT_WEEK
  JOURNAL_30_DAYS
}

enum CompetitionTier {
  T1
  T2
  T3
}

enum LeaderboardMetric {
  SCORE
  MAX_STREAK
  TOTAL_CHECKINS
}

enum UserFocus {
  ENERGY
  FOCUS
  SLEEP
}

enum CheckInPreference {
  MORNING
  EVENING
  LATER
}

enum SocialPressureMode {
  STRONG
  SOFT
}

enum PushDispatchStatus {
  PENDING
  RETRY_PENDING
  DELIVERED
  FAILED
}

enum QuestStatus {
  PENDING
  COMPLETED
  EXPIRED
}

enum StampTier {
  BRONZE
  SILVER
  GOLD
  OBSIDIAN
}

enum DuelStatus {
  PENDING_SELECTION
  SELECTED
  EVALUATED
}

enum DuelChoice {
  A
  B
}

enum DuelResult {
  BETTER
  SAME
  WORSE
}

enum TutorialState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TutorialEventType {
  STARTED
  STEP_SHOWN
  STEP_COMPLETED
  SKIPPED
  COMPLETED
  RESTARTED
}

model User {
  id                  String               @id @default(cuid())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  email               String?              @unique
  passwordHash        String?
  displayName         String?
  displayNameNormalized String?            @unique
  avatarUrl           String?
  avatarSeed          String?
  timezone            String               @default("UTC")
  onboardingComplete  Boolean              @default(false)
  focus               UserFocus            @default(ENERGY)
  checkinPreference   CheckInPreference    @default(EVENING)
  notificationsEnabled Boolean             @default(false)
  slot1HourLocal      Int                  @default(8)
  slot2HourLocal      Int                  @default(20)
  socialPressureMode  SocialPressureMode   @default(STRONG)
  socialPressureCooldownUntil DateTime?
  themeKey            String               @default("obsidian-command")
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  activities          ActivityDefinition[]
  checkIns            CheckIn[]
  journalNotes        JournalNote[]
  sessions            Session[]
  badgeAwards         BadgeAward[]
  gamificationState   GamificationState?
  competitionStats    CompetitionDailyStat[]
  dailyQuests         DailyQuest[]
  bossWeeks           BossWeek[]
  nextMoveDuels       NextMoveDuel[]
  dailyStamps         DailyStamp[]
  pushSubscriptions   PushSubscription[]
  pushDispatches      PushDispatch[]
  engagementStates    EngagementDailyState[]
  tutorialProgress    TutorialProgress[]
  tutorialEvents      TutorialEvent[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model PushSubscription {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String
  p256dh     String
  auth       String
  userAgent  String?
  failCount  Int       @default(0)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  updatedAt  DateTime  @updatedAt
  dispatches PushDispatch[]

  @@unique([userId, endpoint])
  @@index([userId, revokedAt])
}

model PushDispatch {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   PushSubscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  localDate      String
  reminderType   String
  payload        Json
  status         PushDispatchStatus @default(PENDING)
  attemptCount   Int               @default(0)
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  lastError      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, nextAttemptAt])
  @@index([userId, localDate, status])
}

model ActivityDefinition {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  category   String
  type       ActivityType
  isStarter  Boolean      @default(false)
  archivedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  values     CheckInActivityValue[]

  @@unique([userId, name])
  @@index([userId, archivedAt])
}

model CheckIn {
  id            String                @id @default(cuid())
  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime              @default(now())
  localDate     String
  mood          Int
  energy        Int
  journal       String?
  clientEventId String?
  values        CheckInActivityValue[]

  @@index([userId, createdAt])
  @@index([userId, localDate])
  @@unique([userId, clientEventId])
}

model EngagementDailyState {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  localDate        String
  slot1Done        Boolean   @default(false)
  slot2Done        Boolean   @default(false)
  slot1CompletedAt DateTime?
  slot2CompletedAt DateTime?
  perfectDay       Boolean   @default(false)
  pushCount        Int       @default(0)
  lastPushAt       DateTime?
  comebackEligible Boolean   @default(false)
  rescueQuestActive Boolean  @default(false)
  rescueCompletedAt DateTime?
  rescueBonusGranted Boolean @default(false)
  comebackGapDays  Int?
  nextMicroStep    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, localDate])
  @@index([userId, localDate, perfectDay])
}

model JournalNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  localDate String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, localDate, createdAt])
}

model CheckInActivityValue {
  id           String             @id @default(cuid())
  checkInId    String
  checkIn      CheckIn            @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  activityId   String
  activity     ActivityDefinition @relation(fields: [activityId], references: [id], onDelete: Cascade)
  booleanValue Boolean?
  numericValue Int?

  @@unique([checkInId, activityId])
  @@index([activityId])
}

model GamificationState {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  totalCheckIns Int      @default(0)
  totalXp       Int      @default(0)
  level         Int      @default(1)
  comboBps      Int      @default(100)
  lastQuestDate String?
  lastCheckInAt DateTime?
  updatedAt     DateTime @updatedAt
}

model BadgeAward {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     BadgeType
  awardedAt DateTime  @default(now())

  @@unique([userId, badge])
  @@index([userId])
}

model CompetitionDailyStat {
  id                 String          @id @default(cuid())
  userId             String
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  localDate          String
  rawCheckIns        Int             @default(0)
  creditedCheckIns   Int             @default(0)
  journalEntries     Int             @default(0)
  streak             Int             @default(0)
  tier               CompetitionTier @default(T1)
  t3Maintained       Boolean         @default(false)
  t3GraceUsed        Boolean         @default(false)
  bonusPercent       Int             @default(0)
  basePoints         Int             @default(0)
  finalPoints        Int             @default(0)
  activeMultipliers  Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([userId, localDate])
  @@index([userId, localDate])
  @@index([localDate])
}

model LeaderboardSnapshot {
  id         String            @id @default(cuid())
  metric     LeaderboardMetric
  periodKey  String
  generatedAt DateTime         @default(now())
  payload    Json
  version    Int               @default(1)
  stale      Boolean           @default(false)

  @@unique([metric, periodKey])
  @@index([generatedAt])
  @@index([stale])
}

model DailyQuest {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  localDate   String
  focus       UserFocus
  questKey    String
  title       String
  description String
  strategy    String
  activityId  String?
  activityName String?
  numericMin  Int?
  status      QuestStatus @default(PENDING)
  rewardXp    Int         @default(20)
  completedAt DateTime?
  expiredAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, localDate])
  @@index([userId, localDate, status])
}

model BossWeek {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekKey      String
  hpCurrent    Int      @default(7)
  hpMax        Int      @default(7)
  clearedAt    DateTime?
  rewardGranted Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, weekKey])
  @@index([userId, weekKey])
}

model NextMoveDuel {
  id                  String     @id @default(cuid())
  userId              String
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  localDate           String
  sourceCheckInId     String?
  status              DuelStatus @default(PENDING_SELECTION)
  optionATitle        String
  optionAWhy          String
  optionAMinimalVariant String
  optionAConfidence   Int
  optionALag          Int
  optionBTitle        String
  optionBWhy          String
  optionBMinimalVariant String
  optionBConfidence   Int
  optionBLag          Int
  selectedChoice      DuelChoice?
  selectedAt          DateTime?
  result              DuelResult?
  evaluatedAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([userId, localDate])
  @@index([userId, localDate, status])
}

model DailyStamp {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  localDate String
  tier      StampTier
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, localDate])
  @@index([userId, localDate, tier])
}

model TutorialProgress {
  id               String        @id @default(cuid())
  userId           String        @unique
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutorialKey      String
  version          Int
  state            TutorialState @default(NOT_STARTED)
  currentStepId    String?
  completedStepIds Json
  startedAt        DateTime?
  firstCheckinAt   DateTime?
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([tutorialKey, version, state])
}

model TutorialEvent {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutorialKey String
  version     Int
  eventType   TutorialEventType
  stepId      String?
  route       String?
  metadata    Json?
  createdAt   DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([tutorialKey, version, eventType, createdAt])
}
